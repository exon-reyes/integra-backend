@SpringBootTest
@ActiveProfiles("test")
class EmpleadoQueryServiceTest {

    @Autowired
    private EmpleadoQueryService empleadoQueryService;

    @Autowired
    private EmpleadoRepository empleadoRepository;

    @Autowired
    private CacheManager cacheManager;

    @Test
    void debeUsarCacheEnSegundaConsulta() {
        // Given
        String pin = "12345678";
        Cache cache = cacheManager.getCache("empleadoPorNip");
        cache.clear();

        // When - Primera consulta (miss)
        var result1 = empleadoQueryService.findByPin(pin, EmpleadoModelInfo.class);

        // When - Segunda consulta (hit)
        var result2 = empleadoQueryService.findByPin(pin, EmpleadoModelInfo.class);

        // Then
        assertNotNull(cache.get(pin + "_EmpleadoModelInfo"));
        // Verificar que ambos resultados son iguales
        assertEquals(result1, result2);
    }
}
