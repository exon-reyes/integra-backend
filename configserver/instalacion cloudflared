                  CÓD_SALIDA_WIN32   : 0  (0x0)
                  CÓD_SALIDA_SERVICIO: 0  (0x0)
                  PUNTO_COMPROB.     : 0x0
                  INDICACIÓN_INICIO  : 0x0
